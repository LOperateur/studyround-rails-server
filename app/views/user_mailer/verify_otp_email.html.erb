<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width"/>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
  <title>U-Learn Verification Email</title>
  <style>
      body {
          background-color: rgba(255, 128, 81, 0.2);
          font-family: 'Open Sans', sans-serif;
          margin: 0;
      }

      table {
          background-color: white;
          border-radius: 10px;
          box-shadow: 0px 0px 10px 0px lightgray;
          margin: auto auto;
          display: table;
          width: 580px;
          height: 100%;
          padding: 10px 10px 10px 10px;
      }

      .content {
          display: block;
          margin: 50px auto !important;
          /* makes it centered */
          max-width: 600px;
          width: 100%;
      }

      h1 {
          margin: 0;
      }

      a {
          border-radius: 20px;
          transition: all 0.3s ease-in-out;
      }

      a:hover {
          background-color: #333;
          color: white;
          cursor: pointer;
      }
  </style>
</head>
<body>
<div class="content">
  <table>
    <tr>
      <td style="padding: 20px; width: 100px; height: 100px; ">
        <img src="https://ulearn-bucket.s3.amazonaws.com/assets/logo.png" alt="U-learn Logo" width="100" height="100">
      </td>
    </tr>
    <tr>
      <td style="padding: 20px 20px 0 20px;">
        <h1 style="font-size: 24px; color: #333; text-align: center;">Email OTP Verification</h1>
        <p style="font-size: 16px; color: #555; line-height: 1.5; padding: 20px; text-align: center">
          Verify your email <%= @email %>, for U-Learn.
        </p>
        <p style="font-size: 16px; text-align: center;">
          Your otp is:
        </p>
        <p style="font-size: 48px; color: #333; text-align: center;">
          <strong><%= @otp %></strong>
        </p>
      </td>
    </tr>
  </table>
</div>
<p style="font-size: 14px; color: #999; line-height: 1.5; padding: 10px; text-align: center">
  Copyright © 2023 L'Operateur Ltd. Nigeria
</p>
</body>
</html>