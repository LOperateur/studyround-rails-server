<!DOCTYPE html>
<html>
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
  <title>U-Learn Test Results</title>
  <style>
      body {
          background-color: #ff8051;
          font-family: 'Open Sans', sans-serif;
          margin: 0;
      }

      table {
          background-color: white;
          border-radius: 10px;
          box-shadow: 0px 0px 10px 0px lightgray;
          margin: 50px auto;
          display: table;
          width: 600px;
          height: 100%;
      }

      h1 {
          margin: 0;
      }

      a {
          border-radius: 20px;
          transition: all 0.3s ease-in-out;
      }

      a:hover {
          background-color: #333;
          color: white;
          cursor: pointer;
      }
  </style>
</head>
<body>
<table>
  <tr>
    <td style="padding: 20px; width: 100px; height: 100px; ">
      <img src="https://ulearn-bucket.s3.amazonaws.com/assets/logo.png" alt="U-learn Logo" width="100" height="100">
    </td>
  </tr>
  <tr>
    <td style="padding: 20px 20px 0 20px;">
      <h1 style="font-size: 24px; color: #333; text-align: center;">'<%= @title %>' Results!</h1>
      <p style="font-size: 16px; color: #555; line-height: 1.5; padding: 0 20px 0 20px;">
        The test, '<%= @title %>' has been closed by the creator.<br/>
        You score was:
      </p>
      <p style="font-size: 36px; color: #333; padding: 0 20px 0 20px;">
        <strong><%= @score %></strong>
      </p>
      <p style="text-align: center;">
        Click here to view more details about your result:
      </p>
    </td>
  </tr>
  <tr>
    <td style="padding: 0 20px 20px 20px;">
      <p style="text-align: center;">
        <a href="<%=ENV['HOST_URL']%>/result/<%= @result_id %>/review" style="display: inline-block; padding: 12px 20px; background-color: #ff8051; color: #fff; text-decoration: none;">Review Performance</a>
      </p>
    </td>
  </tr>
</table>
</body>
</html>
